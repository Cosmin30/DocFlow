{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },
      "documents-route": {
        "ClusterId": "documents-cluster",
        "Match": {
          "Path": "/documents/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/documents/{**catch-all}"
          }
        ]
      },
      "approvals-route": {
        "ClusterId": "approvals-cluster",
        "Match": {
          "Path": "/approvals/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/approvals/{**catch-all}"
          }
        ]
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": {
          "Path": "/audit/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/audit/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7200/"
          }
        }
      },
      "documents-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7205/"
          }
        }
      },
      "approvals-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7011/"
          }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7108/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "AllowedHosts": "*"
}
